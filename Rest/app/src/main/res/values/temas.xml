<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Rest" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Tema Splash Screen (Android 12+) -->
    <style name="Theme.Rest.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/azul_splash_fondo</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/buho_background</item>
        <item name="android:windowSplashScreenAnimationDuration">1000</item>
        <item name="android:windowDiscoveryForceDarkAllowed" tools:targetApi="29">false</item>
        <!-- Para versiones anteriores a Android 12 -->
        <item name="android:windowBackground">@color/azul_splash_fondo</item>
        <item name="android:statusBarColor">@color/azul_splash_fondo</item>
    </style>
</resources>